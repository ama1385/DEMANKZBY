    /** Pick two rows to compare: intended for in-game BACKPACK (right) vs STASH (left). Selection uses internal map only to suggest rows — verify visually. */
    _logBackpackVsStashFieldSamples() {
        var bpSample = null;
        var stashSample = null;
        for (var i = 0; i < this.inventoryData.length; i++) {
            var it = this.inventoryData[i];
            var flags = this._debugAncestorStashBackpackFlags(it);
            if (flags.backpack && !bpSample) bpSample = it;
            if (flags.stash && !stashSample) stashSample = it;
            if (bpSample && stashSample) break;
        }
        if (!bpSample) {
            var vis = this._getAllVisibleItems();
            if (vis.length) {
                bpSample = vis[0];
                console.warn('[FIELDS] No backpack-ancestor hint; first visible row below — confirm it is actually from BACKPACK in-game.');
            }
        }
        if (!stashSample) {
            var vis2 = this._getAllVisibleItems();
            for (var j = 0; j < vis2.length; j++) {
                if (!bpSample || vis2[j].instanceId !== bpSample.instanceId) {
                    stashSample = vis2[j];
                    console.warn('[FIELDS] No stash-ancestor hint; using a different visible row — confirm it is from STASH in-game.');
                    break;
                }
            }
        }
        console.log('[Backpack filter] Compare with in-game BACKPACK (right). Then set window.__INVENTORY_BACKPACK_RULE__ = { match: { … } } using strict API values.');
        this._logFieldsLine(bpSample);
        console.log('[Backpack filter] Compare with in-game STASH (left).');
        this._logFieldsLine(stashSample);
    }

    _parseCloneIdsResponse(data) {
        var out = [];
        if (data == null) return out;
        if (Array.isArray(data)) {
            for (var i = 0; i < data.length; i++) {
                var x = data[i];
                if (typeof x === 'string') out.push(x);
                else if (x && x.instanceId) out.push(x.instanceId);
            }
            return out;
        }
        var keys = ['instanceIds', 'clones', 'ids', 'items'];
        for (var k = 0; k < keys.length; k++) {
            var arr = data[keys[k]];
            if (Array.isArray(arr)) return this._parseCloneIdsResponse(arr);
        }
        return out;
    }

    /** All rows that pass the normal grid visibility rules (no backpack filter). */
    _getAllVisibleItems() {
        var out = [];
        for (var i = 0; i < this.inventoryData.length; i++) {
            var item = this.inventoryData[i];
            if (this._visibleInGrid(item)) out.push(item);
        }
        return out;
    }

    /**
     * List used for stats and as the starting point for the table (before search/sort).
     * When Backpack Only is on: filter with _isBackpackItem; safe fallback if zero matches.
     */
    _getPreSearchDisplayList(skipWarn) {
        var base = this._getAllVisibleItems();

        // Container filter: 'all', 'stash', 'backpack'
        if (this.containerFilter === 'stash') {
            base = base.filter(function(item) { return !this._isBackpackItem(item); }.bind(this));
        } else if (this.containerFilter === 'backpack') {
            base = base.filter(function(item) { return this._isBackpackItem(item); }.bind(this));
        }

        var strictN = 0;
        for (var s = 0; s < base.length; s++) {
            if (this._isBackpackItem(base[s])) strictN++;
        }
        this._strictBackpackMatchCount = strictN;

        if (!this.backpackOnly) {
            this._backpackFilterFallbackActive = false;
            this._cachedVisibleForTable = base;
            return base;
        }

        var backpackRows = base.filter(function(item) {
            return this._isBackpackItem(item);
        }.bind(this));

        if (backpackRows.length > 0) {
            this._backpackFilterFallbackActive = false;
            this._cachedVisibleForTable = backpackRows;
            return backpackRows;
        }

        if (base.length > 0) {
            if (!skipWarn) {
                console.warn('[Backpack Only] No rows matched window.__INVENTORY_BACKPACK_RULE__. Set { match: { … } } from FIELDS logs (strict ===). Showing all visible items (fallback).');
            }
            this._backpackFilterFallbackActive = true;
            this._cachedVisibleForTable = base;
            return base;
        }

        this._backpackFilterFallbackActive = false;
        this._cachedVisibleForTable = [];
        return [];
    }

