    // Check if a mod is attached to a gun (should be hidden from main list)
    isUnequippedMod(item) {
        const category = this.getItemCategory(item.gameAssetId);
        const isMod = category === 'Modification' || category === 'Mods';
        if (!isMod) return false;

        let containerItem = null;
        for (let i = 0; i < this.inventoryData.length; i++) {
            const container = this.inventoryData[i];
            if (this._slotArrayContainsEntry(container.slots, item.instanceId)) {
                containerItem = container;
                break;
            }
        }

        if (!containerItem) return false;

        const isInInventorySlot = Number(containerItem.gameAssetId) === 1440007245;
        return !isInInventorySlot;
    }

    /** sarc3 visibility + stash grid slot (embedded-safe) */
    _visibleInGrid(item) {
        if (Number(item.gameAssetId) === 1440007245) return false;
        const name = this.getItemName(item.gameAssetId);
        if (!this.showUnindexed && name.startsWith('Unknown')) return false;
        if (this.isBlacklisted(item.gameAssetId)) return false;
        if (this.isUnequippedMod(item)) return false;
        return true;
    }

    /**
     * True if slots[] holds this instance (handles string vs object entries and case-insensitive UUID compare).
     */
    _slotArrayContainsEntry(slots, instanceId) {
        if (!slots || !slots.length) return false;
        var id = String(instanceId).trim().toLowerCase().replace(/[{}]/g, '');
        for (var i = 0; i < slots.length; i++) {
            var s = slots[i];
            if (s == null || s === '') continue;
            if (typeof s === 'object') {
                if (s.instanceId != null && String(s.instanceId).trim().toLowerCase().replace(/[{}]/g, '') === id) return true;
                if (s.itemInstanceId != null && String(s.itemInstanceId).trim().toLowerCase().replace(/[{}]/g, '') === id) return true;
                continue;
            }
            if (String(s).trim().toLowerCase().replace(/[{}]/g, '') === id) return true;
        }
        return false;
    }

    /** Parent container whose `slots` array references this instanceId (if any). */
    _getParentContainer(instanceId) {
        for (var i = 0; i < this.inventoryData.length; i++) {
            var c = this.inventoryData[i];
            if (this._slotArrayContainsEntry(c.slots, instanceId)) return c;
        }
        return null;
    }

    /**
     * Internal only: locate rows to print FIELDS (not used for Backpack Only filtering).
     * Uses container gameAssetIds on the parent chain as a weak hint to pick one stash-side vs one backpack-side row.
     */
    _debugIsStashContainerAsset(gameAssetId) {
        var n = Number(gameAssetId);
        return n === 1440007245 || n === 824256753;
    }

    _debugIsBackpackContainerAsset(gameAssetId) {
        var n = Number(gameAssetId);
        // Known backpack container IDs (original set)
        if (n === 1326799221 || n === 1450686663 || n === -900626342) return true;
        // Known looting augment gameAssetIds (all variants)
        if (n === 303567898 || n === 433079423 || n === 947411243) return true; // MK3 Survivor/Cautious/Safekeeper
        if (n === -1156830089 || n === 1680690244) return true; // Mk.2 / Mk.1
        return false;
    }

    _debugRowIsStashContainer(row) {
        return !!(row && this._debugIsStashContainerAsset(row.gameAssetId));
    }

    _debugRowIsBackpackContainer(row) {
        return !!(row && this._debugIsBackpackContainerAsset(row.gameAssetId));
    }

    _debugAncestorStashBackpackFlags(item) {
        var stash = false;
        var backpack = false;
        var hintIds = [item.containerInstanceId, item.parentInstanceId, item.ownerInstanceId, item.containerId];
        for (var h = 0; h < hintIds.length; h++) {
            var hinted = this._findRowByInstance(hintIds[h]);
            if (!hinted) continue;
            if (this._debugRowIsStashContainer(hinted)) stash = true;
            if (this._debugRowIsBackpackContainer(hinted)) backpack = true;
        }
        var cur = item.instanceId;
        for (var d = 0; d < 32; d++) {
            var parent = this._getParentContainer(cur);
            if (!parent) break;
            if (this._debugRowIsStashContainer(parent)) stash = true;
            if (this._debugRowIsBackpackContainer(parent)) backpack = true;
            cur = parent.instanceId;
        }
        return { stash: stash, backpack: backpack };
    }

    _normalizeInstanceKey(nid) {
        if (nid == null || nid === '') return '';
        return String(nid).trim().toLowerCase().replace(/[{}]/g, '');
    }

    _findRowByInstance(nid) {
        var id = this._normalizeInstanceKey(nid);
        if (!id) return null;
        for (var i = 0; i < this.inventoryData.length; i++) {
            var row = this.inventoryData[i];
            if (this._normalizeInstanceKey(row.instanceId) === id) return row;
        }
        return null;
    }

    /**
     * Backpack Only: strict === on fields you copy from FIELDS logs.
     * Example after you see API values:
     *   window.__INVENTORY_BACKPACK_RULE__ = { match: { area: 'Loadout', equipmentSlotType: 'SomeExactValue' } };
     * Optional: match.slotId, match.slotIds (array), match.slotIdMin / match.slotIdMax, match.gameAssetId
     * All specified keys in match must pass (AND). Omit rule → no rows count as backpack (use fallback UI).
     */
    _isBackpackItem(item) {
        if (!item) return false;
        // Backend tag is the primary source of truth
        if (item._container === 'backpack') return true;
        if (item._container === 'stash') return false;
        // Frontend fallback: walk parent chain looking for a known backpack container
        var cur = item.instanceId;
        for (var d = 0; d < 10; d++) {
            var parent = this._getParentContainer(cur);
            if (!parent) break;
            var gid = Number(parent.gameAssetId);
            // Known backpack container IDs (explicit whitelist)
            if (gid === 1326799221 || gid === 1450686663 || gid === -900626342 ||
                gid === 303567898 || gid === 433079423 || gid === 947411243 ||
                gid === -1156830089 || gid === 1680690244) return true;
            // Hit a stash container → definitely not backpack
            if (gid === 1440007245 || gid === 824256753) return false;
            cur = parent.instanceId;
        }
        // Default: assume stash if backend didn't tag and no known container found
        return false;
        // Legacy window rule (kept for manual override support)
        var w = typeof window !== 'undefined' ? window : null;
        if (!w || !w.__INVENTORY_BACKPACK_RULE__ || typeof w.__INVENTORY_BACKPACK_RULE__ !== 'object') return false;
        var m = w.__INVENTORY_BACKPACK_RULE__.match;
        if (!m || typeof m !== 'object') return false;
        var any = false;
        if (m.area !== undefined) {
            any = true;
            if (item.area !== m.area) return false;
        }
        if (m.equipmentSlotType !== undefined) {
            any = true;
            if (item.equipmentSlotType !== m.equipmentSlotType) return false;
        }
        if (m.slotId !== undefined) {
            any = true;
            if (Number(item.slotId) !== Number(m.slotId)) return false;
        }
        if (Array.isArray(m.slotIds) && m.slotIds.length > 0) {
            any = true;
            var sid = item.slotId == null ? NaN : Number(item.slotId);
            if (m.slotIds.indexOf(sid) === -1) return false;
        }
        if (m.slotIdMin !== undefined) {
            any = true;
            if (item.slotId == null || Number(item.slotId) < m.slotIdMin) return false;
        }
        if (m.slotIdMax !== undefined) {
            any = true;
            if (item.slotId == null || Number(item.slotId) > m.slotIdMax) return false;
        }
        if (m.gameAssetId !== undefined) {
            any = true;
            if (Number(item.gameAssetId) !== Number(m.gameAssetId)) return false;
        }
        return any;
    }

    _logFieldsLine(item) {
        if (!item) {
            console.log('FIELDS:', {
