    _setActivePage(page) {
        var navItems = document.querySelectorAll('.nav-item[data-page]');
        for (var i = 0; i < navItems.length; i++) {
            navItems[i].classList.toggle('is-active', navItems[i].getAttribute('data-page') === page);
        }
        var pages = document.querySelectorAll('.page[data-page]');
        for (var p = 0; p < pages.length; p++) {
            pages[p].classList.toggle('is-active', pages[p].getAttribute('data-page') === page);
        }
        var kicker = document.getElementById('topbarKicker');
        var sub = document.getElementById('topbarSub');
        if (kicker) {
            if (page === 'inventory') kicker.textContent = 'Inventory';
            else if (page === 'settings') kicker.textContent = 'Settings';
            else if (page === 'profiles') kicker.textContent = 'Account Profiles';
        }
        if (sub) {
            if (page === 'inventory') sub.textContent = '';
            else if (page === 'settings') sub.textContent = 'Display and behavior preferences';
            else if (page === 'profiles') sub.textContent = 'Manage your saved accounts';
        }
        // Show/hide refresh button and CR balance only on inventory page
        var refreshBtn = document.getElementById('refreshBtn');
        var crBal = document.getElementById('crBalance');
        if (refreshBtn) refreshBtn.style.display = (page === 'inventory') ? '' : 'none';
        if (crBal && crBal.getAttribute('data-has-cr')) crBal.style.display = (page === 'inventory') ? '' : 'none';
        // Render profiles page
        if (page === 'profiles') this._renderProfilesPage();
    }

    _inferLocation(item) {
        // 1. Direct item fields (fastest, most reliable)
        var area = item.area || item.Area || item.location || item.containerArea || '';
        if (area) {
            var a = String(area).toLowerCase();
            if (a.includes('backpack') || a.includes('bag') || a.includes('carried') || a.includes('equipped')) return 'backpack';
            if (a.includes('stash') || a.includes('storage') || a.includes('vault') || a.includes('depot')) return 'stash';
        }
        var slotType = item.equipmentSlotType || item.slotType || item.containerType || '';
        if (slotType) {
            var st = String(slotType).toLowerCase();
            if (st.includes('backpack') || st.includes('bag')) return 'backpack';
            if (st.includes('stash')) return 'stash';
        }

        // 2. Configured backpack rule
        try {
            if (this._isBackpackItem && this._isBackpackItem(item)) return 'backpack';
        } catch (e) { /* ignore */ }

        // 3. Ancestor chain via known container asset IDs
        var flags = this._debugAncestorStashBackpackFlags ? this._debugAncestorStashBackpackFlags(item) : null;
        if (flags && flags.backpack && !flags.stash) return 'backpack';
        if (flags && flags.stash && !flags.backpack) return 'stash';

        // 4. Top-level structural heuristic: if this item has NO parent in inventoryData,
        //    it is probably a root-level stash item (or the stash/backpack container itself).
        //    If it has a parent that has a parent, it's likely nested (mod in weapon = not a root item).
        var parent = this._getParentContainer(item.instanceId);
        if (!parent) return 'stash'; // no parent → top-level stash slot
        var grandparent = this._getParentContainer(parent.instanceId);
        if (!grandparent) {
            // parent is top-level container → this item is directly inside stash or backpack
            // Use container asset ID to distinguish
            if (this._debugRowIsBackpackContainer && this._debugRowIsBackpackContainer(parent)) return 'backpack';
            return 'stash';
        }
        // Deeper nesting (mod on weapon etc.) — inherit from grandparent's container type
        var ggp = this._getParentContainer(grandparent.instanceId);
        if (ggp && this._debugRowIsBackpackContainer && this._debugRowIsBackpackContainer(ggp)) return 'backpack';
        return 'stash';
    }

    escapeHtml(text) {
        var div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    showLoading(show) {
        var loadingDiv = document.getElementById('loading');
        var refreshBtn = document.getElementById('refreshBtn');
        if (show) {
            if (loadingDiv) loadingDiv.style.display = 'flex';
            if (refreshBtn) {
                refreshBtn.disabled = true;
                refreshBtn.style.opacity = '0.6';
                refreshBtn.innerHTML = '<span class="btn-icon">⏳</span> ' + this.t('loading');
            }
            // Show skeleton cards while loading
            this._showSkeletonCards(12);
        } else {
            if (loadingDiv) loadingDiv.style.display = 'none';
            if (refreshBtn) {
                refreshBtn.disabled = false;
                refreshBtn.style.opacity = '1';
                refreshBtn.innerHTML = '<span class="btn-icon">↻</span> ' + this.t('refreshLabel');
            }
        }
    }

    showError(message) {
        var errorDiv = document.getElementById('errorMessage');
        errorDiv.textContent = message;
        errorDiv.style.display = 'block';
        setTimeout(function() { errorDiv.style.display = 'none'; }, 6000);
    }

    showTemporaryMessage(message, color) {
        if (!color) color = '#10b981';
        var statsDiv = document.getElementById('stats');
        statsDiv.innerHTML = '<span class="stats-pill__inner"><span class="stats-pill__seg" style="color:' + color + '">' + message + '</span></span>';
        setTimeout(function() {
            this.updateStats();
        }.bind(this), 2500);
    }

    // ══════════════════════════════════════════════════════════════
    // CLS SIGNATURE — New Feature Methods
    // ══════════════════════════════════════════════════════════════

    /** Called once to wire up all new Signature UI elements. */
    _initSignatureUI() {
        // Footer year
        var fy = document.getElementById('footerYear');
        if (fy) fy.textContent = new Date().getFullYear();
        var ty = document.getElementById('tokenYear');
        if (ty) ty.textContent = new Date().getFullYear();
        // Sidebar token eye/copy buttons
        var eye  = document.getElementById('sidebarTokenEye');
        var copy = document.getElementById('sidebarTokenCopy');
        var val  = document.getElementById('sidebarTokenVal');
        if (eye && val) {
            eye.onclick = () => {
                val.type = val.type === 'password' ? 'text' : 'password';
            };
        }
        if (copy && val) {
            copy.onclick = () => {
                var t = val.value;
                if (!t) return;
                navigator.clipboard.writeText(t).then(() => {
                    var origColor = copy.style.color;
                    copy.style.color = '#34d399';
                    setTimeout(() => { copy.style.color = origColor; }, 1200);
                }).catch(() => {});
            };
        }
    }

    /** Update the sidebar current token display. */
    _updateTokenReveal(token) {
        var reveal = document.getElementById('sidebarTokenReveal');
        var val    = document.getElementById('sidebarTokenVal');
        if (!reveal || !val) return;
        if (token) {
            val.value = token;
            reveal.style.display = '';
        } else {
            val.value = '';
            reveal.style.display = 'none';
        }
    }

    // ── Session timer ──────────────────────────────────────────────
    _startSessionTimer() {
        if (this._sessionTimerInt) return;
        this._sessionStart = Date.now();
        var self = this;
        this._sessionTimerInt = setInterval(function() {
            var elapsed = Math.floor((Date.now() - self._sessionStart) / 1000);
            var mins = Math.floor(elapsed / 60);
            var secs = elapsed % 60;
            var str = mins + ':' + (secs < 10 ? '0' : '') + secs;
            var sb = document.getElementById('sidebarSessionTime');
            if (sb) sb.textContent = str;
            var hb = document.getElementById('sessionTimerVal');
            if (hb) hb.textContent = str;
            var htimer = document.getElementById('headerSessionTimer');
            if (htimer) htimer.style.display = '';
        }, 1000);
    }

    // ── License countdown ──────────────────────────────────────────
    _setLicenseExpiry(expiryMs) {
        this._licenseExpiry = typeof expiryMs === 'number' ? expiryMs : (Date.parse(expiryMs) || null);
        this._updateLicenseCountdown();
        if (!this._licCountInt) {
            this._licCountInt = setInterval(() => this._updateLicenseCountdown(), 10000);
        }
    }

    _updateLicenseCountdown() {
        if (!this._licenseExpiry) {
            var hlc0 = document.getElementById('headerLicenseCountdown');
            if (hlc0) {
                hlc0.style.display = 'none';
                var hlt0 = document.getElementById('headerLicenseTime');
                if (hlt0) hlt0.textContent = '';
            }
            var sb0 = document.getElementById('sidebarLicenseTime');
            if (sb0) sb0.textContent = '—';
            return;
        }
        var now  = Date.now();
        var diff = this._licenseExpiry - now;
        var str, warning = false;
        if (diff <= 0) {
            str = 'Expired';
            warning = true;
        } else {
            var totalH = Math.floor(diff / 3600000);
            var totalM = Math.floor((diff % 3600000) / 60000);
            if (totalH >= 24) {
                var d = Math.floor(totalH / 24);
                str = d + 'd ' + (totalH % 24) + 'h';
            } else if (totalH > 0) {
                str = totalH + 'h ' + totalM + 'm';
                if (totalH < 2) warning = true;
            } else {
                str = totalM + 'm';
                warning = true;
            }
        }
        // Update sidebar stats card
        var sb = document.getElementById('sidebarLicenseTime');
        if (sb) {
            sb.textContent = str;
            sb.classList.toggle('warning', warning);
        }
        // Update header pill (mobile)
        var hlt = document.getElementById('headerLicenseTime');
        var hlc = document.getElementById('headerLicenseCountdown');
        if (hlt) hlt.textContent = str;
        if (hlc) {
            hlc.style.display = '';
            hlc.classList.toggle('warning', warning);
        }
    }

    // ── Status dot ─────────────────────────────────────────────────
    _startStatusDot() {
        if (this._statusDotInt) return;
        this._checkStatusDot();
        this._statusDotInt = setInterval(() => this._checkStatusDot(), 30000);
    }

    async _checkStatusDot() {
        var dot   = document.getElementById('statusDot');
        var label = document.getElementById('statusDotLabel');
        if (!dot) return;
        var t0 = Date.now();
        try {
            var r = await fetch('/api/auth-status');
            await r.json();
            var ms = Date.now() - t0;
            var lagging = ms > 2500;
            dot.classList.toggle('lagging', lagging);
            if (label) label.textContent = lagging ? 'API lagging (' + ms + 'ms)' : 'Server Optimized';
        } catch {
            dot.classList.add('lagging');
            if (label) label.textContent = 'API unreachable';
        }
    }

    // ── Sound & Haptic ─────────────────────────────────────────────
    _haptic(pattern) {
        if (!this._hapticEnabled) return;
        try {
            if (navigator.vibrate) navigator.vibrate(pattern || [30]);
        } catch {}
    }

    _playChime() {
        if (!this._soundEnabled) return;
        try {
            var ctx = new (window.AudioContext || window.webkitAudioContext)();
            var t = ctx.currentTime;
            var freqs = [880, 1100, 1320];
            freqs.forEach(function(freq, i) {
                var osc = ctx.createOscillator();
                var gain = ctx.createGain();
                osc.connect(gain); gain.connect(ctx.destination);
                osc.type = 'sine';
                osc.frequency.value = freq;
                var start = t + i * 0.12;
                gain.gain.setValueAtTime(0, start);
                gain.gain.linearRampToValueAtTime(0.2, start + 0.04);
                gain.gain.exponentialRampToValueAtTime(0.001, start + 0.35);
                osc.start(start); osc.stop(start + 0.36);
            });
        } catch {}
    }

    /** Called after Refresh IDs or Dupe completes. */
    _onBulkFinished() {
        this._haptic([40, 30, 40]);
        this._playChime();
    }

    // ── Skeleton loading ───────────────────────────────────────────
    /** Show N skeleton cards in the inventory grid while data loads. */
    _showSkeletonCards(n) {
        var grid = document.getElementById('inventoryGrid');
        if (!grid) return;
        var html = '';
        for (var i = 0; i < Math.min(n || 12, 24); i++) {
            html += '<div class="inv-card inv-card--skeleton" aria-hidden="true">' +
                '<div class="inv-card__top">' +
                '  <div class="skel-line skel-icon"></div>' +
                '  <div style="flex:1;min-width:0">' +
                '    <div class="skel-line skel-name"></div>' +
                '    <div class="skel-line skel-meta"></div>' +
                '  </div>' +
                '</div>' +
                '<div class="skel-line skel-qty"></div>' +
                '</div>';
        }
        grid.innerHTML = html;
    }

    // ── Account profiles ───────────────────────────────────────────
    _loadProfiles() {
        try {
            return JSON.parse(localStorage.getItem('deman_profiles') || '[]');
        } catch { return []; }
    }

    _saveProfiles() {
        localStorage.setItem('deman_profiles', JSON.stringify(this._profiles));
    }

    _addProfile(name, token) {
        name  = (name  || '').trim();
        token = (token || '').trim().replace(/^Bearer\s+/i, '');
        if (!name || !token) return { ok: false, msg: 'Name and token are required.' };
        // Prevent duplicates
        var idx = this._profiles.findIndex(function(p) { return p.name === name; });
        if (idx >= 0) {
            this._profiles[idx].token = token;
        } else {
            this._profiles.push({ name: name, token: token, saved: Date.now() });
        }
        this._saveProfiles();
        return { ok: true };
    }

    _deleteProfile(name) {
        this._profiles = this._profiles.filter(function(p) { return p.name !== name; });
        this._saveProfiles();
    }

    _loadProfileToken(name) {
        var p = this._profiles.find(function(p) { return p.name === name; });
        if (!p) return null;
        return p.token;
    }

    async _applyProfileToken(token) {
        if (!token) return;
        try {
            var resp = await fetch('/api/set-token', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: token })
            });
            if (!resp.ok) {
                const ej = await resp.json().catch(() => ({}));
                this.showError(ej.error || 'Could not apply token');
                return;
            }
            this._updateTokenReveal(token);
            // Reload inventory with new token
            await this.loadInventory();
        } catch (e) {
            console.warn('Profile token apply failed:', e);
        }
    }

    _renderProfilesList(listId) {
        var el = document.getElementById(listId || 'profilesList');
        if (!el) return;
        var profiles = this._profiles;
        if (!profiles.length) {
            el.innerHTML = '<div style="color:var(--text-muted);font-size:0.8rem;padding:4px 0">No profiles saved yet.</div>';
            return;
        }
        var html = '';
        for (var i = 0; i < profiles.length; i++) {
            var p = profiles[i];
            var safeName = p.name.replace(/</g,'&lt;').replace(/>/g,'&gt;');
            html += '<div class="profile-item" data-profile-name="' + safeName + '">' +
                '<div class="profile-item__avatar">' +
                '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>' +
                '</div>' +
                '<span class="profile-item__name" title="' + safeName + '">' + safeName + '</span>' +
                '<button type="button" class="profile-item__btn profile-item__btn--load" data-load="' + safeName + '">Load</button>' +
                '<button type="button" class="profile-item__btn profile-item__btn--del" data-del="' + safeName + '" title="Delete profile">×</button>' +
                '</div>';
        }
        el.innerHTML = html;
        // Bind buttons
        var self = this;
        el.querySelectorAll('[data-load]').forEach(function(btn) {
            btn.onclick = function() {
                var name  = btn.getAttribute('data-load');
                var token = self._loadProfileToken(name);
                if (token) {
                    self._applyProfileToken(token);
                    self._setProfileStatus(listId, 'Profile "' + name + '" loaded.', true);
                }
            };
        });
        el.querySelectorAll('[data-del]').forEach(function(btn) {
            btn.onclick = function() {
                var name = btn.getAttribute('data-del');
                self._deleteProfile(name);
                self._renderProfilesList(listId);
                self._renderProfilesList('profilesListP');
                self._setProfileStatus(listId, 'Profile deleted.', true);
            };
        });
    }

    _setProfileStatus(listId, msg, isOk) {
        var statusId = listId === 'profilesListP' ? 'profileStatusP' : 'profileStatus';
        var el = document.getElementById(statusId);
        if (!el) return;
        el.textContent = msg;
        el.className = 'profile-status ' + (isOk ? 'is-ok' : 'is-error');
        setTimeout(function() { if (el) el.textContent = ''; }, 3500);
    }

    _initProfilesSection(nameId, saveBtnId, manualNameId, manualTokenId, addBtnId, listId, statusId) {
        var self = this;
        var saveBtn = document.getElementById(saveBtnId);
        if (saveBtn) {
            saveBtn.onclick = function() {
                var nameInp  = document.getElementById(nameId);
                var name     = nameInp ? nameInp.value.trim() : '';
                var curToken = document.getElementById('sidebarTokenVal');
                var token    = (curToken && curToken.value) ? curToken.value.trim() : '';
                if (!token) {
                    self._setProfileStatus(listId, 'No active token — sign in or load a profile with a token first.', false);
                    return;
                }
                var res = self._addProfile(name, token);
                if (res.ok) {
                    if (nameInp) nameInp.value = '';
                    self._renderProfilesList(listId);
                    self._renderProfilesList('profilesListP');
                    self._setProfileStatus(listId, 'Profile "' + name + '" saved!', true);
                } else {
                    self._setProfileStatus(listId, res.msg, false);
                }
            };
        }
        var addBtn = document.getElementById(addBtnId);
        if (addBtn) {
            addBtn.onclick = function() {
                var mnInp  = document.getElementById(manualNameId);
                var mtInp  = document.getElementById(manualTokenId);
                var name   = mnInp ? mnInp.value.trim() : '';
                var token  = mtInp ? mtInp.value.trim() : '';
                var res    = self._addProfile(name, token);
                if (res.ok) {
                    if (mnInp) mnInp.value = '';
                    if (mtInp) mtInp.value = '';
                    self._renderProfilesList(listId);
                    self._renderProfilesList('profilesListP');
                    self._setProfileStatus(listId, 'Profile "' + name + '" added!', true);
                } else {
                    self._setProfileStatus(listId, res.msg, false);
                }
            };
        }
    }

    _renderProfilesPage() {
        this._initProfilesSection('profileNameInputP', 'saveProfileBtnP', 'manualProfileNameInputP', 'manualTokenInputP', 'addManualProfileBtnP', 'profilesListP', 'profileStatusP');
        this._renderProfilesList('profilesListP');
    }
}

