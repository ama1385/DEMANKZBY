    updateSelectAllCheckbox() {
        var selectAll = document.getElementById('selectAllCheckbox');
        if (!selectAll) return;
        var allBoxes = document.querySelectorAll('.row-checkbox:not(.select-all-checkbox)');
        if (allBoxes.length === 0) { selectAll.checked = false; selectAll.indeterminate = false; return; }
        var checkedCount = 0;
        for (var i = 0; i < allBoxes.length; i++) {
            if (allBoxes[i].checked) checkedCount++;
        }
        if (checkedCount === 0) { selectAll.checked = false; selectAll.indeterminate = false; }
        else if (checkedCount === allBoxes.length) { selectAll.checked = true; selectAll.indeterminate = false; }
        else { selectAll.checked = false; selectAll.indeterminate = true; }
    }

    updateStats() {
        var visibleItems = this._getPreSearchDisplayList(true);
        var total = visibleItems.length;
        var totalAmount = 0;
        for (var i = 0; i < visibleItems.length; i++) {
            totalAmount += (visibleItems[i].amount || 1);
        }
        var identified = 0;
        for (var i = 0; i < visibleItems.length; i++) {
            if (!this.getItemName(visibleItems[i].gameAssetId).startsWith('Unknown')) {
                identified++;
            }
        }
        var timeStr = InventoryViewer._formatTimeRho();
        var sep = '<span class="stats-pill__sep" aria-hidden="true">·</span>';
        var refreshedVisible = 0;
        for (var rv = 0; rv < visibleItems.length; rv++) {
            if (this._isSessionRefreshedItem(visibleItems[rv])) refreshedVisible++;
        }
        var refreshedSeg = '';
        if (refreshedVisible > 0) {
            refreshedSeg =
                sep +
                '<span class="stats-pill__seg stats-pill__seg--refreshed">' +
                '<span class="stats-pill__ico" aria-hidden="true">✨</span> ' +
                refreshedVisible +
                ' ' + this.t('refreshedPill') +
                '</span>';
        }
        var coinsSeg = '';
        if (this.crBalance !== null && !isNaN(Number(this.crBalance))) {
            coinsSeg =
                sep +
                '<span class="stats-pill__seg"><span class="stats-pill__ico" aria-hidden="true">🪙</span> ' +
                Number(this.crBalance).toLocaleString('en-US') +
                ' Coins</span>';
        }
        // Show / hide the dedicated Clear badges button in the filter bar
        var clearBadgesBtn = document.getElementById('clearBadgesBtn');
        if (clearBadgesBtn) clearBadgesBtn.style.display = refreshedVisible > 0 ? '' : 'none';
        document.getElementById('stats').innerHTML =
            '<span class="stats-pill__inner">' +
            '<span class="stats-pill__seg"><span class="stats-pill__ico" aria-hidden="true">📦</span> ' + total.toLocaleString('en-US') + ' ' + this.escapeHtml(this.t('statItems')) + '</span>' +
            sep +
            '<span class="stats-pill__seg"><span class="stats-pill__ico" aria-hidden="true">🔢</span> ' + totalAmount.toLocaleString('en-US') + ' ' + this.escapeHtml(this.t('statUnits')) + '</span>' +
            sep +
            '<span class="stats-pill__seg"><span class="stats-pill__ico" aria-hidden="true">✅</span> ' + identified.toLocaleString('en-US') + ' ' + this.escapeHtml(this.t('statIdentified')) + '</span>' +
            coinsSeg +
            refreshedSeg +
            sep +
            '<span class="stats-pill__seg stats-pill__time">' + timeStr + '</span>' +
            '</span>';

        var ev = document.getElementById('estimatedValue');
        if (ev) {
            // No reliable CR pricing dataset is bundled; keep UI responsive with a lightweight proxy metric.
            ev.textContent = totalAmount.toLocaleString('en-US') + ' units';
        }
    }

    static _formatTimeRho() {
        var d = new Date();
        var pad = function(n) { return String(n).padStart(2, '0'); };
        return pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds()) + ' \u2374';
    }

    filterAndDisplay() {
        if (!this.inventoryData.length) {
            this._cachedVisibleForTable = [];
            this.renderCards([]);
            this._syncBulkActions();
            return;
        }

        var filtered = this._getPreSearchDisplayList(false);

        var searchEl = document.getElementById('searchInput');
        var search = searchEl ? searchEl.value.toLowerCase() : '';
        if (search) {
            var searchFiltered = [];
            for (var i = 0; i < filtered.length; i++) {
                var it = filtered[i];
                var name = this.getItemName(it.gameAssetId);
                if (name.toLowerCase().includes(search) || String(it.gameAssetId).includes(search)) {
                    searchFiltered.push(it);
                }
            }
            filtered = searchFiltered;
        }

        var sortByEl = document.getElementById('sortBy');
        var sortBy = sortByEl ? sortByEl.value : 'name';
        filtered.sort(function(a, b) {
            if (sortBy === 'amount') return (b.amount || 0) - (a.amount || 0);
            if (sortBy === 'name') return this.getItemName(a.gameAssetId).localeCompare(this.getItemName(b.gameAssetId));
            return (b.updatedAt || 0) - (a.updatedAt || 0);
        }.bind(this));

        if (this.showRefreshedOnly) {
            var rf = [];
            for (var ri = 0; ri < filtered.length; ri++) {
                if (this._isSessionRefreshedItem(filtered[ri])) rf.push(filtered[ri]);
            }
            filtered = rf;
        }

        this.syncRefreshedOnlyToggleUI();
        this._cachedVisibleForTable = filtered.slice(0);
        this.renderCards(filtered);
        this._syncBulkActions();
    }

    renderCards(items) {
        if (!items) items = [];
        var container = document.getElementById('inventoryGrid');
        if (!container) return;

        if (!items.length) {
            var emptyMsg = this.t('noItems');
            var _si = document.getElementById('searchInput');
            var q = (_si ? _si.value : '').trim();
            if (!q && this.showRefreshedOnly && this.inventoryData.length > 0) {
                emptyMsg = this.t('noRefreshedFilter');
            }
            container.innerHTML = '<div class="placeholder"><div class="placeholder__title">No items</div><div class="placeholder__text">' + this.escapeHtml(emptyMsg) + '</div></div>';
            return;
        }

        var html = '';
        for (var i = 0; i < items.length; i++) {
            var item = items[i];
            var name = this.getItemName(item.gameAssetId);
            var icon = this.getItemIcon(item.gameAssetId);
            var category = this.getItemCategory(item.gameAssetId);
            var amount = item.amount || 1;
            var isSelected = this.selectedIds.has(item.instanceId);
            var isCloned = this.cloneInstanceIds.has(item.instanceId);
            var isRefreshed = this._isSessionRefreshedItem(item);
            var loc = this._inferLocation(item);
            var title = 'Location: ' + (loc === 'stash' ? 'Stash Slot' : (loc === 'backpack' ? 'Backpack' : 'Unknown')) + ' | ID: ' + item.instanceId;

            // Resolve weapon attachment mod icons (slots → slot containers → mods)
            var attachHtml = '';
            if (item.slots && item.slots.length > 0 && item.slots[0] !== '') {
                var modIcons = [];
                for (var si = 0; si < item.slots.length && modIcons.length < 6; si++) {
                    var slotContId = item.slots[si];
                    var slotCont = null;
                    for (var sj = 0; sj < this.inventoryData.length; sj++) {
                        if (this.inventoryData[sj].instanceId === slotContId) { slotCont = this.inventoryData[sj]; break; }
                    }
                    if (!slotCont) continue;
                    var modSlots = (slotCont.slots && slotCont.slots[0] !== '') ? slotCont.slots : [];
                    for (var sk = 0; sk < modSlots.length && modIcons.length < 6; sk++) {
                        var modItem = null;
                        for (var sm = 0; sm < this.inventoryData.length; sm++) {
                            if (this.inventoryData[sm].instanceId === modSlots[sk]) { modItem = this.inventoryData[sm]; break; }
                        }
                        if (!modItem) continue;
                        var modIcon = this.getItemIcon(modItem.gameAssetId);
                        var modName = this.getItemName(modItem.gameAssetId);
                        if (modIcon) {
                            modIcons.push('<img src="' + this.escapeHtml(modIcon) + '" alt="' + this.escapeHtml(modName) + '" title="' + this.escapeHtml(modName) + '" class="inv-card__attach-img" data-inv-attach>');
                        } else {
                            modIcons.push('<span class="inv-card__attach-empty" title="' + this.escapeHtml(modName || 'Empty') + '">▭</span>');
                        }
                    }
                    // show empty slot placeholder if no mod
                    if (modSlots.length === 0) {
                        modIcons.push('<span class="inv-card__attach-empty" title="Empty slot">▭</span>');
                    }
                }
                if (modIcons.length > 0) {
                    attachHtml = '<div class="inv-card__attach">' + modIcons.join('') + '</div>';
                }
            }

            html += '<div class="inv-card' + (isSelected ? ' is-selected' : '') + '" data-instance="' + this.escapeHtml(item.instanceId) + '" title="' + this.escapeHtml(title) + '">';
            html += '<div class="inv-card__qty">x' + this.escapeHtml(String(amount)) + '</div>';
            html += '<div class="inv-card__top">';
            html += '<div class="inv-card__icon">';
            if (icon) {
                html += '<img src="' + this.escapeHtml(icon) + '" alt="" decoding="async" loading="lazy" data-inv-img>';
            } else {
                html += '<span class="no-icon">🎮</span>';
            }
            html += '</div>';
            html += '<div class="inv-card__title">';
            html += '<div class="inv-card__name">' + this.escapeHtml(name) + (isCloned ? ' <span class="cloned-badge">CLONED</span>' : '') + (isRefreshed ? ' <span class="refreshed-badge" title="' + this.escapeHtml(this.t('badgeRefTitle')) + '">' + this.escapeHtml(this.t('lblRefreshed')) + '</span>' : '') + '</div>';
            if (attachHtml) html += attachHtml;
            html += '<div class="inv-card__meta">';
            html += '<span class="inv-card__pill">' + this.escapeHtml(category) + '</span>';
            html += '</div>';
            html += '</div>';
            html += '</div>';
            html += '<div class="inv-card__actions">';
            html += '<button type="button" class="inv-mini-btn" data-action="refresh-id">🔄 Refresh ID</button>';
            html += '</div>';
            html += '</div>';
        }
        container.innerHTML = html;

        // Attach onerror handlers after render — avoids inline JS escape issues.
        var imgs = container.querySelectorAll('img[data-inv-img]');
        for (var ii = 0; ii < imgs.length; ii++) {
            imgs[ii].onerror = function() { this.style.display = 'none'; };
        }
        var attachImgs = container.querySelectorAll('img[data-inv-attach]');
        for (var ai = 0; ai < attachImgs.length; ai++) {
            attachImgs[ai].onerror = function() { this.style.display = 'none'; };
        }

        container.onclick = function(e) {
            var card = e.target.closest('.inv-card');
            if (!card) return;
            var instanceId = card.getAttribute('data-instance');
            if (!instanceId) return;

            var actBtn = e.target.closest('[data-action="refresh-id"]');
            if (actBtn) {
                e.preventDefault();
                e.stopPropagation();
                var item = this._findRowByInstance(instanceId);
                if (!item) return;
                var name = this.getItemName(item.gameAssetId);
                var ok = confirm('Refresh Instance ID (Recursive)\n\nItem: ' + name + '\nCurrent ID: ' + instanceId + '\n\nContinue?');
                if (!ok) return;
                actBtn.disabled = true;
                this.showLoading(true);
                this.refreshItemId(item).then(function() {
                    this.showTemporaryMessage(this.t('msgIdUpdated', { name: name }), '#10b981');
                    setTimeout(function() { this.loadInventory(); }.bind(this), 150);
                }.bind(this)).catch(function(err) {
                    this.showError('Refresh ID failed: ' + err.message);
                    actBtn.disabled = false;
                    this.showLoading(false);
                }.bind(this));
                return;
            }

            this._toggleSelected(instanceId);
            card.classList.toggle('is-selected', this.selectedIds.has(instanceId));
            this._syncBulkActions();
            this._syncSelectionCount();
        }.bind(this);
    }

