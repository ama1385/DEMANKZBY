    async loadInventory() {
        if (this.isLoading) return;
        this.isLoading = true;
        this.showLoading(true);
        try {
            var nocache = Date.now();
            var fetchOpts = {
                cache: 'no-store',
                headers: {
                    'Cache-Control': 'no-cache, no-store, must-revalidate',
                    'Pragma': 'no-cache'
                }
            };
            const [resp, cResp] = await Promise.all([
                fetch('/api/inventory?nocache=' + nocache, fetchOpts),
                fetch('/api/clones?nocache=' + nocache, fetchOpts).catch(function() { return null; })
            ]);
            if (resp.status === 403) {
                document.getElementById('keyauthOverlay').classList.remove('hidden');
                const st403 = await this.checkAuth();
                this.showKeyauthOverlay(st403.panel);
                throw new Error('KeyAuth license required');
            } else if (resp.status === 401) {
                document.getElementById('tokenOverlay').classList.remove('hidden');
                this.showTokenOverlay('Your token was rejected — it may be expired or invalid. Get a fresh one above, or paste it below.');
                throw new Error('Token required');
            }
            if (!resp.ok) throw new Error('HTTP ' + resp.status);
            const data = await resp.json();
            if (Array.isArray(data)) {
                this.inventoryData = data;
            } else if (data && typeof data === 'object') {
                this.inventoryData =
                    data.items ||
                    data.Items ||
                    data.inventory ||
                    data.Inventory ||
                    data.data ||
                    [];
                if (!Array.isArray(this.inventoryData)) this.inventoryData = [];
            } else {
                this.inventoryData = [];
            }
            if (this.inventoryData.length) {
                this._logBackpackVsStashFieldSamples();
            }

            this.cloneInstanceIds = new Set();
            if (cResp && cResp.ok) {
                try {
                    const cdata = await cResp.json();
                    var cidList = this._parseCloneIdsResponse(cdata);
                    for (var ci = 0; ci < cidList.length; ci++) {
                        this.cloneInstanceIds.add(cidList[ci]);
                    }
                } catch (e) {
                    console.warn('[clones] parse failed:', e);
                }
            }

            this._pruneSessionRefreshedIds();

            this.selectedIds.forEach(id => {
                if (!this.inventoryData.find(i => i.instanceId === id)) this.selectedIds.delete(id);
            });
            console.log('Loaded ' + this.inventoryData.length + ' items (full inventory on server)');
            this.updateStats();
            if (this.inventoryData.length) {
                this.filterAndDisplay();
            } else {
                this._cachedVisibleForTable = [];
                this.renderCards([]);
                this._syncBulkActions();
            }
            var shown = this._cachedVisibleForTable || [];
            this.showTemporaryMessage(this.t('msgListUpdated', { n: shown.length }), '#10b981');
            this.loadSession();
        } catch (err) {
            console.error('Error loading inventory:', err);
            this.showError(err.message);
        } finally {
            this.isLoading = false;
            this.showLoading(false);
        }
    }

    async refreshItemId(item) {
        const name = this.getItemName(item.gameAssetId);
        console.log('Refreshing ID for: ' + name + ' (' + item.instanceId + ')');

        const response = await fetch('/api/change-id', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ targetId: item.instanceId })
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
            throw new Error(result.error || result.message || 'Change ID failed');
        }

        var newId = result.new_id != null ? result.new_id : result.newId;
        console.log('Refreshed: ' + name + ' -> ' + newId);
        this._registerRefreshedNewId(newId);
        return newId;
    }

    async bulkRefreshSelected() {
        if (this.selectedIds.size === 0) {
            alert(this.t('bulkNoSelect'));
            return;
        }

        const count = this.selectedIds.size;
        const instanceIds = [...this.selectedIds];
        this.selectedIds.clear();
        this._syncBulkActions();

        var BULK_CHUNK = 300;
        var jobs = [];
        for (var ji = 0; ji < instanceIds.length; ji++) {
            var jid = instanceIds[ji];
            var jitem = this.inventoryData.find(function(i) { return i.instanceId === jid; });
            if (!jitem) {
                continue;
            }
            jobs.push({ id: jid, name: this.getItemName(jitem.gameAssetId) });
        }

        var total = jobs.length;
        var skipped = instanceIds.length - total;
        const progress = this.showBulkProgress(total || 1);

        let done = 0, failed = skipped;
        const errors = [];
        if (skipped > 0) {
            errors.push(skipped + ' item(s) not found in current list');
        }

        if (total === 0) {
            progress.update(1, 'Nothing to refresh');
            progress.finish(done, failed, errors);
            setTimeout(function() { this.loadInventory(); }.bind(this), 150);
            return;
        }

        var processed = 0;
        for (var c = 0; c < jobs.length; c += BULK_CHUNK) {
            var slice = jobs.slice(c, c + BULK_CHUNK);
            var ids = slice.map(function(j) { return j.id; });
            var batchNum = Math.floor(c / BULK_CHUNK) + 1;
            progress.update(processed, this.t('batchLine', { b: batchNum, n: slice.length }));

            try {
                var resp = await fetch('/api/change-id-bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ targetIds: ids })
                });
                var data = await resp.json().catch(function() { return {}; });
                if (!resp.ok) {
                    for (var fi = 0; fi < slice.length; fi++) {
                        failed++;
                        errors.push(slice[fi].name + ': ' + (data.error || 'HTTP ' + resp.status));
                        processed++;
                        progress.update(processed, processed + ' / ' + total);
                    }
                    continue;
                }
                var results = data.results || [];
                for (var ri = 0; ri < slice.length; ri++) {
                    var job = slice[ri];
                    var r = results[ri];
                    if (r && r.targetId === job.id && r.success) {
                        done++;
                        if (r.new_id) {
                            this._registerRefreshedNewId(r.new_id);
                        }
                    } else if (r && r.targetId === job.id) {
                        failed++;
                        errors.push(job.name + ': ' + (r.error || this.t('errFailed')));
                    } else {
                        failed++;
                        errors.push(job.name + ': ' + this.t('errUnexpected'));
                    }
                    processed++;
                    progress.update(processed, '⚡ ' + processed + ' / ' + total);
                }
            } catch (err) {
                console.error('Bulk chunk error:', err);
                for (var ei = 0; ei < slice.length; ei++) {
                    failed++;
                    errors.push(slice[ei].name + ': ' + err.message);
                    processed++;
                    progress.update(processed, processed + ' / ' + total);
                }
            }
        }

        progress.finish(done, failed, errors);
        this._onBulkFinished();
        setTimeout(function() { this.loadInventory(); }.bind(this), 150);
    }

    // ── Super Safe Pocket ─────────────────────────────────────────────────────
    // Processes each selected item one-by-one using /api/change-id (sequential,
    // no prompt, takes time — shows live per-item progress).

    async safePocket() {
        if (this.selectedIds.size === 0) return;

        const instanceIds = [...this.selectedIds];
        this.selectedIds.clear();
        this._syncBulkActions();

        const total = instanceIds.length;
        const overlay = this._showSafePocketBulkOverlay(total);

        try {
            const resp = await fetch('/api/safe-pocket', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ targetIds: instanceIds, cycles: 1 })
            });
            const data = await resp.json().catch(function() { return {}; });

            if (!resp.ok || !data.ok) {
                overlay.finish(0, total, 0, 0, [data.error || data.message || 'Failed']);
            } else {
                const succeeded = data.succeeded || 0;
                const safeCopied = data.safe_copied || 0;
                const skipped = data.skipped || 0;
                const failed = Math.max(0, total - succeeded - safeCopied - skipped);
                overlay.finish(succeeded, failed, skipped, safeCopied, []);
            }
        } catch (err) {
            overlay.finish(0, total, [err.message || 'Network error']);
        }

        this._onBulkFinished();
        setTimeout(function() { this.loadInventory(); }.bind(this), 300);
    }

