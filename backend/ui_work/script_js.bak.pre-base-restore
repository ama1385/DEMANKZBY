    _sessionRefreshedStorageKey() {
        return 'arcInvSessionRefreshedIds';
    }

    /** Grace period (ms) after Refresh ID: inventory fetch may still list the old id briefly — do not drop the new id mark yet. */
    static _REFRESHED_GRACE_MS() {
        return 180000;
    }

    _normInstanceId(id) {
        return String(id || '').trim().toLowerCase().replace(/[{}]/g, '');
    }

    _readRefreshedStorageRaw() {
        try {
            return localStorage.getItem(this._sessionRefreshedStorageKey()) || sessionStorage.getItem(this._sessionRefreshedStorageKey());
        } catch (e) {
            try {
                return sessionStorage.getItem(this._sessionRefreshedStorageKey());
            } catch (e2) {
                return null;
            }
        }
    }

    _writeRefreshedStorageRaw(str) {
        try {
            localStorage.setItem(this._sessionRefreshedStorageKey(), str);
        } catch (e) { /* ignore */ }
        try {
            sessionStorage.setItem(this._sessionRefreshedStorageKey(), str);
        } catch (e2) { /* ignore */ }
    }

    _loadSessionRefreshedIds() {
        this._refreshedGraceUntil = {};
        try {
            var raw = this._readRefreshedStorageRaw();
            if (!raw) return;
            var parsed = JSON.parse(raw);
            if (Array.isArray(parsed)) {
                for (var i = 0; i < parsed.length; i++) {
                    this.refreshedInstanceIds.add(this._normInstanceId(parsed[i]));
                }
                return;
            }
            if (parsed && parsed.v === 2 && Array.isArray(parsed.ids)) {
                for (var j = 0; j < parsed.ids.length; j++) {
                    this.refreshedInstanceIds.add(this._normInstanceId(parsed.ids[j]));
                }
                if (parsed.grace && typeof parsed.grace === 'object') {
                    for (var gk in parsed.grace) {
                        if (!Object.prototype.hasOwnProperty.call(parsed.grace, gk)) continue;
                        var nk = this._normInstanceId(gk);
                        this._refreshedGraceUntil[nk] = Number(parsed.grace[gk]) || 0;
                    }
                }
            }
        } catch (e) { /* ignore */ }
    }

    _saveSessionRefreshedIds() {
        try {
            this._writeRefreshedStorageRaw(
                JSON.stringify({
                    v: 2,
                    ids: Array.from(this.refreshedInstanceIds),
                    grace: this._refreshedGraceUntil,
                })
            );
        } catch (e) { /* ignore */ }
    }

    _pruneSessionRefreshedIds() {
        var valid = {};
        for (var i = 0; i < this.inventoryData.length; i++) {
            valid[this._normInstanceId(this.inventoryData[i].instanceId)] = true;
        }
        var now = Date.now();
        var next = new Set();
        var nextGrace = {};
        this.refreshedInstanceIds.forEach(function(id) {
            if (valid[id]) {
                next.add(id);
                if (this._refreshedGraceUntil[id]) nextGrace[id] = this._refreshedGraceUntil[id];
            } else if (this._refreshedGraceUntil[id] && now < this._refreshedGraceUntil[id]) {
                next.add(id);
                nextGrace[id] = this._refreshedGraceUntil[id];
            }
        }.bind(this));
        this.refreshedInstanceIds = next;
        this._refreshedGraceUntil = nextGrace;
        this._saveSessionRefreshedIds();
    }

    _isSessionRefreshedItem(item) {
        return this.refreshedInstanceIds.has(this._normInstanceId(item.instanceId));
    }

    _registerRefreshedNewId(newId) {
        if (!newId) return;
        var n = this._normInstanceId(newId);
        this.refreshedInstanceIds.add(n);
        this._refreshedGraceUntil[n] = Date.now() + InventoryViewer._REFRESHED_GRACE_MS();
        this._saveSessionRefreshedIds();
    }

    clearSessionRefreshedMarks() {
        this.refreshedInstanceIds.clear();
        this._refreshedGraceUntil = {};
        try {
            localStorage.removeItem(this._sessionRefreshedStorageKey());
        } catch (e) { /* ignore */ }
        try {
            sessionStorage.removeItem(this._sessionRefreshedStorageKey());
        } catch (e2) { /* ignore */ }
        this.filterAndDisplay();
        this.updateStats();
    }

    t(key, vars) {
        var bundle = UI_I18N[this.lang] || UI_I18N.en;
        var s = bundle[key];
        if (s === undefined) s = UI_I18N.en[key];
        if (s === undefined) return key;
        if (vars && typeof s === 'string') {
            Object.keys(vars).forEach(function(k) {
                s = s.split('{' + k + '}').join(String(vars[k]));
            });
        }
        return s;
    }

