    async _initBrowserPicker() {
        var sel    = document.getElementById('settingBrowser');
        var status = document.getElementById('browserPickerStatus');
        if (!sel) return;

        try {
            var r    = await fetch('/api/browsers');
            var data = await r.json();
            var browsers  = data.browsers  || [];
            var current   = data.current   || '';

            sel.innerHTML = '';
            browsers.forEach(function(b) {
                var opt      = document.createElement('option');
                opt.value    = b.path;
                opt.textContent = b.name;
                if (b.path === current) opt.selected = true;
                sel.appendChild(opt);
            });

            if (status) status.textContent = current
                ? '✓ Saved'
                : '';
        } catch (e) {
            if (sel) sel.innerHTML = '<option value="">Could not detect browsers</option>';
        }

        sel.onchange = async () => {
            var path = sel.value;
            if (status) { status.textContent = '…'; status.style.color = '#a78bfa'; }
            try {
                var resp = await fetch('/api/set-browser', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ path: path })
                });
                var d = await resp.json().catch(() => ({}));
                if (!resp.ok) throw new Error(d.error || 'Failed');
                if (status) {
                    status.textContent = path ? '✓ Saved — takes effect next launch' : '✓ Using system default';
                    status.style.color = '#10b981';
                }
            } catch (e) {
                if (status) { status.textContent = '✗ ' + (e.message || 'Error'); status.style.color = '#ef4444'; }
            }
        };
    }

    /** Build a map of gameAssetId → total amount from current inventoryData */
    _buildIdSnapshot() {
        var map = {};
        var data = this.inventoryData || [];
        for (var i = 0; i < data.length; i++) {
            var id = String(data[i].gameAssetId);
            var amt = Number(data[i].amount) || 1;
            map[id] = (map[id] || 0) + amt;
        }
        return map;
    }

    _findIdAction() {
        var data = this.inventoryData;
        if (!data || !data.length) {
            console.warn('[Find ID] No inventory data — refresh inventory first.');
            return;
        }
        var btn = document.getElementById('findIdBtn');
        var status = document.getElementById('findIdStatus');

        // Phase 1: no snapshot yet → take snapshot
        if (!this._findIdSnapshot) {
            this._findIdSnapshot = this._buildIdSnapshot();
            var count = Object.keys(this._findIdSnapshot).length;
            if (btn) btn.textContent = '🔍 Find Changed';
            if (status) status.textContent = '✅ Snapshot taken (' + count + ' unique IDs). Remove an item in-game, refresh inventory, then click Find Changed.';
            console.log('[Find ID] Snapshot saved —', count, 'unique gameAssetIds recorded.');
            return;
        }

        // Phase 2: snapshot exists → diff
        var before = this._findIdSnapshot;
        var after = this._buildIdSnapshot();

        var removed = [];   // in before, gone or reduced in after
        var added = [];     // new in after (not in before)

        var allIds = new Set(Object.keys(before).concat(Object.keys(after)));
        allIds.forEach(function(id) {
            var bAmt = before[id] || 0;
            var aAmt = after[id] || 0;
            if (bAmt > 0 && aAmt < bAmt) {
                removed.push({ gameAssetId: id, before: bAmt, after: aAmt, diff: bAmt - aAmt });
            } else if (aAmt > 0 && bAmt === 0) {
                added.push({ gameAssetId: id, after: aAmt });
            }
        }.bind(this));

        if (removed.length === 0 && added.length === 0) {
            if (status) status.textContent = '⚠️ No changes detected. Make sure you refreshed inventory after removing the item.';
            console.log('[Find ID] No differences found between snapshot and current inventory.');
            return;
        }

        if (removed.length > 0) {
            console.group('[Find ID] Removed / reduced IDs (' + removed.length + '):');
            removed.forEach(function(entry) {
                var name = this.getItemName(entry.gameAssetId);
                console.log(
                    'gameAssetId:', entry.gameAssetId,
                    '| name:', name,
                    '| was:', entry.before,
                    '| now:', entry.after,
                    '| removed:', entry.diff
                );
            }.bind(this));
            console.groupEnd();
        }

        if (added.length > 0) {
            console.group('[Find ID] Newly appeared IDs (' + added.length + '):');
            added.forEach(function(entry) {
                var name = this.getItemName(entry.gameAssetId);
                console.log('gameAssetId:', entry.gameAssetId, '| name:', name, '| amount:', entry.after);
            }.bind(this));
            console.groupEnd();
        }

        var summary = removed.length + ' removed, ' + added.length + ' added.';
        if (status) status.textContent = '🔎 Done — ' + summary + ' Check the browser console (F12).';
        console.log('[Find ID] Complete —', summary);

        // Reset so user can take a new snapshot
        this._findIdSnapshot = null;
        if (btn) btn.textContent = '📷 Snapshot';
        if (status) {
            var s = status;
            setTimeout(function() {
                if (s.textContent.startsWith('🔎')) s.textContent = 'Snapshot cleared. Click Snapshot to start again.';
            }, 6000);
        }
    }

    _applyCardSize(size) {
