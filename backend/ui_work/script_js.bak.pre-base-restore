    // ── Dupe Backpack — Infinite Refresh Loop ─────────────────────────────────

    startDupeLoop() {
        if (this.selectedIds.size === 0) {
            alert('No items selected.\nCheck the boxes first.');
            return;
        }

        // Snapshot the current instanceIds — we track them ourselves as they rotate
        this._loopInstanceIds = [...this.selectedIds];

        this._loopController = new AbortController();
        this._loopActive     = true;
        this._loopCount      = 0;
        this._updateDupeBtn();
        this._loopRun(); // starts the loop (no await — runs independently in background)
    }

    stopDupeLoop() {
        this._loopActive = false;
        // Abort all in-flight requests instantly
        if (this._loopController) {
            this._loopController.abort();
            this._loopController = null;
        }
        this._updateDupeBtn();
        this.loadInventory();
    }

    _updateDupeBtn() {
        var btn = document.getElementById('bulkSafePocketBtn');
        if (!btn) return;
        if (this._loopActive) {
            btn.textContent = '⏹ STOP';
            btn.style.background = 'linear-gradient(135deg,#7f1d1d,#ef4444)';
            btn.style.color = '#fff';
            btn.style.borderColor = '#ef4444';
        } else {
            btn.textContent = '✨ DUPE BACKPACK';
            btn.style.background = '';
            btn.style.color = '';
            btn.style.borderColor = '';
        }
    }

    async _loopRun() {
        var signal = this._loopController ? this._loopController.signal : null;

        while (this._loopActive) {
            var ids = this._loopInstanceIds.slice();
            if (!ids.length) break;

            try {
                // Fire immediately — no delay between iterations
                var resp = await fetch('/api/change-id-bulk', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ targetIds: ids }),
                    signal: signal
                });

                if (resp.ok) {
                    var data = await resp.json();
                    var results = data.results || [];
                    // Update tracked IDs from the server's new_id — always fresh, never stale
                    for (var i = 0; i < results.length; i++) {
                        var r = results[i];
                        if (r && r.success && r.targetId && r.new_id) {
                            var idx = this._loopInstanceIds.indexOf(r.targetId);
                            if (idx !== -1) this._loopInstanceIds[idx] = r.new_id;
                        }
                    }
                }
            } catch (err) {
                if (err && err.name === 'AbortError') return; // STOP pressed — exit cleanly
                // Any other transient error: brief pause then retry
                await new Promise(function(res) { setTimeout(res, 100); });
            }
            // No setTimeout delay — next iteration fires the instant this one finishes
        }
    }

