class InventoryViewer {
    constructor() {
        this.inventoryData = [];
        this.itemIcons = {};
        this.itemNames = {};
        this.itemCategories = {};
        this.itemBlacklist = new Set();
        this.isLoading = false;
        this.selectedIds = new Set();
        this._oauthRunning = false;
        this.cloneInstanceIds = new Set();
        this._backpackFilterFallbackActive = false;
        this._cachedVisibleForTable = [];
        this.backpackOnly = false;
        this._strictBackpackMatchCount = 0;
        this.containerFilter = 'all'; // 'all' | 'stash' | 'backpack'
        this.showRefreshedOnly = false;
        this.showUnindexed = false;
        this.slotFilter = 'all';
        this.lang = 'en';
        /** Instance IDs (normalized) that received a successful Refresh ID — for UI badges. */
        this.refreshedInstanceIds = new Set();
        /** normId -> epoch ms; keep mark until inventory catches up (API can lag one fetch). */
        this._refreshedGraceUntil = {};
        this._loadSessionRefreshedIds();
        this.sessionData = null;
        this.crBalance = null;

        // Dupe loop state
        this._loopActive      = false;
        this._loopTimer       = null;
        this._loopCount       = 0;
        this._loopInstanceIds = []; // current tracked instanceIds — updated after each success
        this._loopController  = null; // AbortController — kills all in-flight requests on STOP

        // Signature features
        this._sessionStart    = Date.now();
        this._sessionTimerInt = null;
        this._licenseExpiry   = null; // ms epoch; set from auth-status
        this._statusDotInt    = null;
        this._profiles        = this._loadProfiles();
        this._soundEnabled    = (localStorage.getItem('deman_sound') === '1');
        this._hapticEnabled   = (localStorage.getItem('deman_haptic') !== '0');

        this.init();
    }

    async init() {
        this.applyLang(); this.bindEvents();
        this._initSignatureUI();
        const st = await this.checkAuth();
        if (st.allOk) {
            document.getElementById('keyauthOverlay').classList.add('hidden');
            document.getElementById('tokenOverlay').classList.add('hidden');
            this._startSessionTimer();
            this._startStatusDot();
            if (st.licenseExpiry) this._setLicenseExpiry(st.licenseExpiry);
            await this.loadData(); await this.loadInventory(); return;
        }
        if (st.keyauthRequired && !st.keyauth) {
            document.getElementById('keyauthOverlay').classList.remove('hidden');
            this.showKeyauthOverlay(st.panel); return;
        }
        document.getElementById('tokenOverlay').classList.remove('hidden');
        this.showTokenOverlay();
    }

    async checkAuth() {
        try {
            const r = await fetch('/api/auth-status');
            const j = await r.json();
            const panel = j.keyauth_panel || 'https://keyauth.win/app/?page=licenses';
            const keyauthRequired = !!j.keyauth_required;
            const keyauth = keyauthRequired ? !!j.keyauth : true;
            const token = !!j.token;
            const allOk = !!j.ok && keyauth && token;
            // License expiry — KeyAuth may expose expiry_date or expires_at
            let licenseExpiry = j.license_expiry || j.expires_at || null;
            if (!licenseExpiry && j.keyauth_expires_at != null && j.keyauth_expires_at !== '') {
                const at = Number(j.keyauth_expires_at);
                if (at > 0) licenseExpiry = at < 1e12 ? at * 1000 : at;
            }
            if (!licenseExpiry && j.keyauth_remaining_seconds != null && j.keyauth_remaining_seconds !== '') {
                const rs = Number(j.keyauth_remaining_seconds);
                if (!isNaN(rs) && rs >= 0) licenseExpiry = Date.now() + rs * 1000;
            }
            // Update current token in sidebar if available
            if (j.token_value) this._updateTokenReveal(j.token_value);
            return { allOk, keyauthRequired, keyauth, token, panel, licenseExpiry };
        } catch {
            return { allOk: false, keyauthRequired: false, keyauth: false, token: false, panel: 'https://keyauth.win/app/?page=licenses', licenseExpiry: null };
        }
    }

    showKeyauthOverlay(panelUrl) {
        const ov  = document.getElementById('keyauthOverlay');
        const err = document.getElementById('keyauthError');
        const inp = document.getElementById('keyauthInput');
        const btn = document.getElementById('keyauthSaveBtn');
        const lnk = document.getElementById('keyauthPanelLink');
        if (lnk && panelUrl) lnk.href = panelUrl;
        ov.classList.remove('hidden');
        if (err) { err.classList.remove('is-visible'); err.textContent = ''; }

        const submit = async () => {
            const raw = (inp ? inp.value || '' : '').trim();
            if (!raw) {
                if (err) { err.textContent = 'Enter your license key first.'; err.classList.add('is-visible'); }
                return;
            }
            if (btn) btn.disabled = true;
            if (err) err.classList.remove('is-visible');
            try {
                const resp = await fetch('/api/set-keyauth-license', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ license: raw })
                });
                const data = await resp.json().catch(() => ({}));
                if (!resp.ok) throw new Error(data.error || `HTTP ${resp.status}`);
                ov.classList.add('hidden');
                // Re-check auth to decide next step
                const st2 = await this.checkAuth();
                if (st2.allOk) {
                    document.getElementById('tokenOverlay').classList.add('hidden');
                    this._startSessionTimer();
                    this._startStatusDot();
                    if (st2.licenseExpiry) this._setLicenseExpiry(st2.licenseExpiry);
                    await this.loadData(); await this.loadInventory();
                } else {
                    document.getElementById('tokenOverlay').classList.remove('hidden');
                    this.showTokenOverlay();
                }
            } catch (e) {
                if (err) { err.textContent = e.message || 'Invalid license key'; err.classList.add('is-visible'); }
            } finally {
                if (btn) btn.disabled = false;
            }
        };

        if (btn) btn.onclick = submit;
        if (inp) inp.onkeydown = (e) => { if (e.key === 'Enter') submit(); };
        setTimeout(() => { if (inp) inp.focus(); }, 100);
    }

    showTokenOverlay(hint) {
        const ov      = document.getElementById('tokenOverlay');
        const err     = document.getElementById('tokenError');
        const inp     = document.getElementById('tokenInput');
        const btn     = document.getElementById('tokenSaveBtn');
        const eye     = document.getElementById('tokenInputEye');
        const dismiss = document.getElementById('tokenOverlayDismiss');

        // Reset state every time overlay is shown
        ov.classList.remove('hidden');
        err.classList.remove('is-visible');
        err.textContent = '';
        btn.disabled = false;
        inp.value = '';
        inp.type = 'password';
        const helpPanel = document.getElementById('tokenOauthHelp');
        if (helpPanel) helpPanel.classList.add('hidden');

        // Show caller-supplied reason (e.g. "token rejected") AFTER the reset
        if (hint) {
            err.textContent = hint;
            err.classList.add('is-visible');
        }

        // Dismiss button — hides overlay so user can reach Settings
        if (dismiss) {
            dismiss.onclick = () => { ov.classList.add('hidden'); };
        }
        // Skip for now button
        const skipBtn = document.getElementById('tokenSkipBtn');
        if (skipBtn) {
            skipBtn.onclick = () => { ov.classList.add('hidden'); this._startSessionTimer(); this._startStatusDot(); };
        }

        // Eye toggle
        if (eye) {
            eye.onclick = () => {
                inp.type = inp.type === 'password' ? 'text' : 'password';
                eye.style.color = inp.type === 'text' ? 'var(--purple-400)' : '';
            };
        }

        // Prevent stacking listeners
        if (this._tokenSubmitHandler) {
            btn.removeEventListener('click', this._tokenSubmitHandler);
        }

        this._tokenSubmitHandler = async () => {
            const raw = (inp.value || '').trim().replace(/^Bearer\s+/i, '').trim();
            if (!raw) {
                err.textContent = 'Enter your token first.';
                err.classList.add('is-visible');
                return;
            }
            btn.disabled = true;
            btn.querySelector('span').textContent = 'Saving…';
            err.classList.remove('is-visible');
            try {
                const resp = await fetch('/api/set-token', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: raw })
                });
                const data = await resp.json().catch(() => ({}));
                if (!resp.ok) throw new Error(data.error || `Server error ${resp.status}`);
                // Full reload — avoids the overlay-loop caused by calling
                // loadInventory() here (game API may reject an expired token
                // with 401, which would immediately re-show this overlay).
                window.location.reload();
            } catch (e) {
                err.textContent = e.message || 'Could not save token — check the value and try again.';
                err.classList.add('is-visible');
                btn.disabled = false;
                btn.querySelector('span').textContent = 'Continue';
            }
        };

        btn.addEventListener('click', this._tokenSubmitHandler);
        inp.onkeydown = (e) => { if (e.key === 'Enter') { e.preventDefault(); this._tokenSubmitHandler(); } };
        setTimeout(() => inp.focus(), 80);
    }

    _oauthProviderLabel(provider) {
        const m = {
            steam: 'Steam',
            epic: 'Epic Games',
            xbox: 'Xbox',
            playstation: 'PlayStation',
        };
        return m[provider] || provider;
    }

    _allAuthPlatformControls() {
        return Array.from(document.querySelectorAll('[data-provider]'));
    }

    /**
     * Web OAuth: open Embark authorize URL, user pastes localhost redirect URL with code.
     * @param {'controls'|'token'} ctx
     * @param {string} provider steam | epic | xbox | playstation
     */
    async startOAuthFlow(ctx, provider) {
        const prov = provider || 'xbox';
        if (this._oauthRunning) return;
        const self = this;
        const errEl = ctx === 'token' ? document.getElementById('tokenError') : null;
        const label = this._oauthProviderLabel(prov);
        const platformBtns = this._allAuthPlatformControls();
        this._oauthRunning = true;
        platformBtns.forEach((b) => { b.disabled = true; });
        if (errEl) {
            errEl.classList.remove('is-visible');
            errEl.textContent = '';
        }
        const helpPanel = document.getElementById('tokenOauthHelp');
        if (helpPanel) helpPanel.classList.add('hidden');
        if (ctx === 'controls') {
            this.showTemporaryMessage(`Sign-in: use the link in the dialog, then paste the redirect URL. (${label})`, '#a78bfa');
        }
        try {
            const start = await fetch('/api/start-oauth', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ provider: prov }),
            });
            const startData = await start.json().catch(() => ({}));
            if (start.status === 409) {
                throw new Error('Login already in progress — cancel and try again.');
            }
            if (!start.ok) {
                throw new Error(startData.error || `HTTP ${start.status}`);
            }
            const authUrl = startData.auth_url;
            if (!authUrl) throw new Error('Server did not return a sign-in URL.');

            const modal = document.getElementById('oauthPasteOverlay');
            const link = document.getElementById('oauthPasteOpenLink');
            const ta = document.getElementById('oauthPasteUrlInput');
            const subBtn = document.getElementById('oauthPasteSubmitBtn');
            const canBtn = document.getElementById('oauthPasteCancelBtn');
            const errBox = document.getElementById('oauthPasteErr');
            if (!modal || !link || !ta || !subBtn || !canBtn) {
                window.open(authUrl, '_blank', 'noopener,noreferrer');
                throw new Error('Paste-URL dialog missing — use the landing page sign-in if this persists.');
            }
            const showOauthErr = (m) => {
                if (!errBox) return;
                errBox.textContent = m || '';
                errBox.classList.toggle('is-visible', !!m);
            };
            link.href = authUrl;
            ta.value = '';
            showOauthErr('');
            modal.classList.remove('hidden');

            const cleanup = () => {
                modal.classList.add('hidden');
                ta.value = '';
                showOauthErr('');
                subBtn.onclick = null;
                canBtn.onclick = null;
                const bdel = modal.querySelector('[data-oauth-close="1"]');
                if (bdel) bdel.onclick = null;
            };

            canBtn.onclick = () => {
                fetch('/api/oauth-cancel', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' }).catch(() => {});
                cleanup();
            };
            const bdel = modal.querySelector('[data-oauth-close="1"]');
            if (bdel) {
                bdel.onclick = () => {
                    fetch('/api/oauth-cancel', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' }).catch(() => {});
                    cleanup();
                };
            }

            subBtn.onclick = async () => {
                const pasted = (ta.value || '').trim();
                if (!pasted) {
                    showOauthErr('Paste the full URL from your browser address bar.');
                    return;
                }
                subBtn.disabled = true;
                showOauthErr('');
                try {
                    const ex = await fetch('/api/oauth-submit-redirect', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ redirect_url: pasted }),
                    });
                    const ej = await ex.json().catch(() => ({}));
                    if (!ex.ok) throw new Error(ej.error || 'HTTP ' + ex.status);
                    cleanup();
                    if (ctx === 'token') {
                        const ov = document.getElementById('tokenOverlay');
                        if (ov) ov.classList.add('hidden');
                    }
                    await self.loadData();
                    await self.loadInventory();
                    self.showTemporaryMessage(`Token saved — ${label} OK`, '#10b981');
                } catch (e) {
                    showOauthErr(e.message || 'Could not complete sign-in.');
                } finally {
                    subBtn.disabled = false;
                }
            };
        } catch (e) {
            const msg = e.message || 'OAuth error';
            const isMsBlock = /different device|authentication method|retry|blocked|sign.in/i.test(msg);
            if (errEl) {
                errEl.textContent = isMsBlock && prov === 'xbox'
                    ? 'Microsoft blocked the login. See the help panel below.'
                    : msg;
                errEl.classList.add('is-visible');
            } else {
                self.showError(msg);
            }
            if (prov === 'xbox' && (isMsBlock || msg.toLowerCase().includes('oauth'))) {
                const hp = document.getElementById('tokenOauthHelp');
                if (hp) hp.classList.remove('hidden');
            }
        } finally {
            this._oauthRunning = false;
            platformBtns.forEach((b) => { b.disabled = false; });
        }
    }

    async loadData() {
        try {
            const ts = Date.now();
            const [iconsRes, namesRes, catsRes, blackRes] = await Promise.all([
                fetch(`/data/item_icons.json?nocache=${ts}`),
                fetch(`/data/item_names.json?nocache=${ts}`),
                fetch(`/data/item_categories.json?nocache=${ts}`),
                fetch(`/data/item_blacklist.json?nocache=${ts}`)
            ]);
            this.itemIcons = await iconsRes.json();
            this.itemNames = await namesRes.json();
            this.itemCategories = await catsRes.json();
            const blacklistArr = await blackRes.json();
            this.itemBlacklist = new Set(blacklistArr.map(id => String(id)));
            console.log('Loaded data files');
        } catch (err) {
            console.error('Error loading data:', err);
        }
    }

    /**
     * Turn API/JWT name fields into a plain string (Embark often nests displayName as an object).
     */
    _coerceDisplayString(v, depth) {
        if (v == null) return null;
        if (typeof depth !== 'number') depth = 0;
        if (depth > 6) return null;
        if (typeof v === 'string') {
            var t = v.trim();
            return t ? t : null;
        }
        if (typeof v === 'number' && !isNaN(v)) return String(v);
        if (typeof v !== 'object') return null;
        var nestedKeys = ['displayName', 'name', 'value', 'text', 'en', 'default', 'localizedString', 'username', 'gamertag', 'nickname'];
        for (var i = 0; i < nestedKeys.length; i++) {
            var nk = nestedKeys[i];
            if (Object.prototype.hasOwnProperty.call(v, nk) && v[nk] != null) {
                var inner = this._coerceDisplayString(v[nk], depth + 1);
                if (inner) return inner;
            }
        }
        return null;
    }

    _pickProfileDisplayName(profile) {
        if (!profile || typeof profile !== 'object') return null;
        var keys = ['displayName', 'name', 'username', 'playerName', 'nickname', 'personaName', 'publicName', 'gamertag'];
        for (var k = 0; k < keys.length; k++) {
            var v = profile[keys[k]];
            var s = this._coerceDisplayString(v);
            if (s) return s;
        }
        if (profile.profile && typeof profile.profile === 'object') {
            var n = this._pickProfileDisplayName(profile.profile);
            if (n) return n;
        }
        if (profile.data && typeof profile.data === 'object') {
            var n2 = this._pickProfileDisplayName(profile.data);
            if (n2) return n2;
        }
        return null;
    }

    async loadSession() {
        try {
            var r = await fetch('/api/session?nocache=' + Date.now(), {
                cache: 'no-store',
                headers: { 'Cache-Control': 'no-cache, no-store, must-revalidate', 'Pragma': 'no-cache' }
            });
            if (!r.ok) return;
            var data = await r.json();
            this.sessionData = data;
            this._renderHeaderAccount(data);
        } catch (e) {
            console.warn('loadSession', e);
        }
        // Try to load CR balance in background
        this._loadCRBalance();
    }

    async _loadCRBalance() {
        try {
            var r = await fetch('/api/currencies', { cache: 'no-store' });
            if (!r.ok) return;
            var data = await r.json();
            // Try various shapes: { cr: 1000 }, { currencies: [{ type:'CR', amount: 1000 }] },
            // { balance: 1000 }, { credits: 1000 }, { data: { cr: 1000 } }
            var cr = null;
            var toNumber = function(v) {
                if (typeof v === 'number' && !isNaN(v)) return v;
                if (typeof v === 'string') {
                    var cleaned = v.replace(/,/g, '').trim();
                    if (!cleaned) return null;
                    var n = Number(cleaned);
                    if (!isNaN(n)) return n;
                }
                return null;
            };
            var pickByMeaning = function(root) {
                var stack = [root];
                var seen = [];
                while (stack.length) {
                    var cur = stack.pop();
                    if (!cur || typeof cur !== 'object') continue;
                    if (seen.indexOf(cur) !== -1) continue;
                    seen.push(cur);
                    if (Array.isArray(cur)) {
                        for (var ai = 0; ai < cur.length; ai++) stack.push(cur[ai]);
                        continue;
                    }
                    var keys = Object.keys(cur);
                    for (var ki = 0; ki < keys.length; ki++) {
                        var key = keys[ki];
                        var val = cur[key];
                        var lk = String(key || '').toLowerCase();
                        if (lk.includes('coin') || lk.includes('credit') || lk === 'cr' || lk.includes('currency')) {
                            var kNum = toNumber(val);
                            if (kNum !== null) return kNum;
                        }
                        if (val && typeof val === 'object') {
                            if (!Array.isArray(val)) {
                                var t = String(val.type || val.name || val.currency || val.code || key || '').toLowerCase();
                                if (t.includes('coin') || t.includes('credit') || t.includes('cr') || t.includes('currency')) {
                                    var vNum = toNumber(val.amount);
                                    if (vNum === null) vNum = toNumber(val.balance);
                                    if (vNum === null) vNum = toNumber(val.value);
                                    if (vNum === null) vNum = toNumber(val.total);
                                    if (vNum !== null) return vNum;
                                }
                            }
                            stack.push(val);
                        }
                    }
                }
                return null;
            };
            if (data && typeof data === 'object') {
                // Direct number fields
                for (var k of ['cr', 'CR', 'credits', 'Credit', 'balance', 'amount', 'coins']) {
                    var direct = toNumber(data[k]);
                    if (direct !== null) { cr = direct; break; }
                }
                // Array of currency objects
                if (cr === null) {
                    var pools = [data.currencies, data.wallet, data.values];
                    for (var pi = 0; pi < pools.length && cr === null; pi++) {
                        if (!Array.isArray(pools[pi])) continue;
                        for (var ci = 0; ci < pools[pi].length; ci++) {
                            var c = pools[pi][ci] || {};
                            var t = (c.type || c.name || c.currency || c.code || '').toLowerCase();
                            if (t.includes('cr') || t.includes('credit') || t.includes('coin')) {
                                var fromObj = toNumber(c.amount);
                                if (fromObj === null) fromObj = toNumber(c.balance);
                                if (fromObj === null) fromObj = toNumber(c.value);
                                if (fromObj === null) fromObj = toNumber(c.total);
                                if (fromObj !== null) {
                                    cr = fromObj;
                                    break;
                                }
                            }
                        }
                    }
                }
                // Nested data
                if (cr === null && data.data && typeof data.data === 'object') {
                    for (var dk of ['cr', 'CR', 'credits', 'balance', 'coins', 'amount']) {
                        var nested = toNumber(data.data[dk]);
                        if (nested !== null) { cr = nested; break; }
                    }
                }
                if (cr === null) {
                    cr = pickByMeaning(data);
                }
            }
            var crEl = document.getElementById('crBalance');
            var crVal = document.getElementById('crBalanceVal');
            if (crEl && crVal && cr !== null) {
                crVal.textContent = Number(cr).toLocaleString();
                crEl.style.display = '';
                crEl.setAttribute('data-has-cr', '1');
            }
            this.crBalance = (cr !== null && !isNaN(Number(cr))) ? Number(cr) : null;
            this.updateStats();
        } catch (e) {
            // Silently fail — CR is non-critical
        }
    }

